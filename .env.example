# ==========================================
# SUPABASE CONFIGURATION (Wajib Diisi)
# ==========================================
# Ambil dari Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
# (Opsional tapi direkomendasikan untuk fungsi Admin/Backend)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ==========================================
# CLOUDINARY CONFIGURATION (Untuk Fitur Upload Foto)
# ==========================================
# Ambil dari Cloudinary Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ==========================================
# ZENO.FM CONFIGURATION (Untuk Radio Player)
# ==========================================
# Ambil ID stasiun radio ZenoFM (opsional, bisa juga diisi lewat Dashboard Admin)
# NEXT_PUBLIC_ZENO_STATION_ID="cnho9wgxkkovv"

# ==========================================
# LAST.FM CONFIGURATION (Segera Hadir)
# ==========================================
# NEXT_PUBLIC_LASTFM_USERNAME="your-username"
# NEXT_PUBLIC_LASTFM_API_KEY="your-api-key"
